AZURE_REALTIME_API_KEY=wss://servicename.cognitiveservices.azure.com/openai/realtime?api-version=2024-10-01-preview&deployment=gpt-realtime
AZURE_REALTIME_BASE_URL=apikeygoeshere
WEBSOCKET_SERVER="websocket_server" # Options: 'fast_api' or 'websocket_server'


# Azure Speech Services (STT and TTS)
AZURE_SPEECH_API_KEY=your_azure_speech_api_key_here
AZURE_SPEECH_REGION=eastus 

# Azure OpenAI (LLM)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your_deployment_name